		"eslint": "^10.7.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"postcss": "^8.5.21",
		"prettier": "^3.9.6",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "npm:@typescript/typescript6@^6.0.2",
		"typescript7": "npm:typescript@^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@fontsource/space-grotesk": "^5.3.0",
		"prettier-plugin-tailwindcss": "^0.8.1",
