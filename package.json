		"eslint": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"postcss": "^8.5.15",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte-check": "^4.7.0",
		"tailwindcss": "^4.3.1",
		"vite": "^8.1.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource/space-grotesk": "^5.2.10",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.3"
	}
